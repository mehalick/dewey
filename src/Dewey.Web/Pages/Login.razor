@page "/login"
@using Dewey.Web.Auth
@using Dewey.Web.Shared
@inject CognitoClient Cognito
@inject AuthSession Session
@inject NavigationManager Nav

<PageTitle>Sign in - Dewey</PageTitle>

<div class="container" style="max-width: 420px; margin-top: 4rem;">
    <h1 class="mb-4">Sign in</h1>

    @if (_step == Step.Email)
    {
        <EditForm Model="this" OnValidSubmit="StartAsync">
            <div class="mb-3">
                <label class="form-label" for="login-email">Email</label>
                <input id="login-email" class="form-control" type="email" required
                       autocomplete="email" inputmode="email" @bind="_email" />
            </div>
            <button class="btn btn-primary" type="submit" disabled="@_busy">
                @(_busy ? "Sending…" : "Send code")
            </button>
        </EditForm>
    }
    else
    {
        <p>Enter the 6-digit code sent to <strong>@_email</strong>.</p>
        <p class="text-muted small">
            Dev note: until SES is wired, the code is in CloudWatch logs of the
            Cognito triggers Lambda.
        </p>
        <EditForm Model="this" OnValidSubmit="VerifyAsync">
            <div class="mb-3">
                <label class="form-label" for="login-code">Code</label>
                <input id="login-code" class="form-control"
                       inputmode="numeric" pattern="[0-9]*" maxlength="6"
                       autocomplete="one-time-code" required @bind="_code" />
            </div>
            <button class="btn btn-primary" type="submit" disabled="@_busy">
                @(_busy ? "Verifying…" : "Sign in")
            </button>
            <button type="button" class="btn btn-link" @onclick="ResendAsync" disabled="@_busy">
                Resend code
            </button>
            <button type="button" class="btn btn-link" @onclick="Reset">Use a different email</button>
        </EditForm>
    }

    @if (!string.IsNullOrEmpty(_error))
    {
        <div class="alert alert-danger mt-3" role="alert" aria-live="polite">@_error</div>
    }
</div>

@code {
    private enum Step { Email, Code }
    private Step _step = Step.Email;
    private string _email = "";
    private string _code = "";
    private string? _session;
    private string? _error;
    private bool _busy;

    private async Task StartAsync()
    {
        _busy = true; _error = null;
        try
        {
            try
            {
                await Cognito.SignUpAsync(_email, CognitoClient.GenerateRandomPassword());
            }
            catch (CognitoException ex) when (ex.Message.Contains("UsernameExistsException"))
            {
                // expected on returning users
            }

            var res = await Cognito.InitiateCustomAuthAsync(_email);
            _session = res.Session;
            _step = Step.Code;
        }
        catch (Exception ex) { _error = Errors.Friendly(ex, "Couldn't send a code."); }
        finally { _busy = false; }
    }

    private async Task VerifyAsync()
    {
        _busy = true; _error = null;
        try
        {
            var res = await Cognito.RespondToCustomChallengeAsync(_email, _code, _session ?? "");
            if (res.AuthenticationResult is { } auth)
            {
                await Session.SetAsync(new AuthTokens(
                    auth.IdToken, auth.AccessToken, auth.RefreshToken ?? "", _email));
                Nav.NavigateTo("/");
            }
            else
            {
                _session = res.Session;
                _error = "Incorrect code, try again.";
                _code = "";
            }
        }
        catch (Exception ex) { _error = Errors.Friendly(ex, "Sign-in failed."); }
        finally { _busy = false; }
    }

    private async Task ResendAsync()
    {
        // Re-initiate the auth flow; gets a fresh code/session.
        _code = "";
        await StartAsync();
    }

    private void Reset()
    {
        _step = Step.Email;
        _code = "";
        _session = null;
        _error = null;
    }
}
