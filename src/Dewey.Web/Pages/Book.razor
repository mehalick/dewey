@page "/book/{BookId}"
@using Dewey.Shared.Contracts
@using Dewey.Web.Offline
@using Dewey.Web.Shared
@inject HttpClient Http
@inject NavigationManager Nav
@inject ApiCache Cache
@inject Outbox Outbox

<PageTitle>@(_book?.Title ?? "Book") - Dewey</PageTitle>

@if (_book is null && _error is null)
{
    <Spinner Label="Loading book…" />
}
else if (_error is not null)
{
    <div class="alert alert-danger" role="alert">@_error</div>
}
else
{
    <div class="d-flex gap-3 flex-wrap">
        @if (!string.IsNullOrEmpty(_book!.CoverUrl))
        {
            <img src="@_book.CoverUrl" alt="@($"Cover of {_book.Title}")" style="width:160px; height:auto;" />
        }
        <div class="flex-grow-1">
            <h1>@_book.Title</h1>
            <p class="text-muted">@string.Join(", ", _book.Authors)</p>
            @if (_book.PageCount is not null)
            {
                <p>@_book.PageCount pages</p>
            }
            <p>Progress: <strong>@_book.LatestProgressPct%</strong> — @_book.Status</p>
            @if (_book.LatestSessionAt is not null)
            {
                <p class="text-muted small">Last activity: @_book.LatestSessionAt</p>
            }
        </div>
    </div>

    <hr />

    <h2 class="h4">Log a session</h2>
    <div class="row g-2 align-items-end mb-3" style="max-width:560px;">
        <div class="col-auto">
            <label class="form-label" for="progress-pct">Progress %</label>
            <input id="progress-pct" class="form-control" type="number" min="0" max="100"
                   inputmode="numeric" @bind="_progressPct" />
        </div>
        <div class="col-auto">
            <button class="btn btn-success" @onclick="@(() => LogAsync("start"))" disabled="@_logging">Start</button>
        </div>
        <div class="col-auto">
            <button class="btn btn-warning" @onclick="@(() => LogAsync("stop"))" disabled="@_logging">Stop</button>
        </div>
        <div class="col-auto">
            <a class="btn btn-link" href="@($"book/{BookId}/history")">View history</a>
        </div>
    </div>

    <hr />
    <button class="btn btn-outline-danger"
            @onclick="DeleteAsync"
            disabled="@_deleting"
            aria-label="@($"Remove {_book.Title} from library")">
        @(_deleting ? "Removing…" : "Remove from library")
    </button>
}

@code {
    [Parameter] public string BookId { get; set; } = "";
    private BookSummary? _book;
    private string? _error;
    private bool _deleting;
    private bool _logging;
    private int _progressPct;

    protected override async Task OnInitializedAsync() => await LoadAsync();

    private async Task LoadAsync()
    {
        try
        {
            _book = await Cache.GetAsync<BookSummary>($"api/books/{BookId}");
            _progressPct = _book?.LatestProgressPct ?? 0;
        }
        catch (Exception ex) { _error = Errors.Friendly(ex, "Couldn't load this book."); }
    }

    private async Task LogAsync(string type)
    {
        _logging = true; _error = null;
        try
        {
            var req = new LogSessionRequest(
                SessionId: Guid.NewGuid().ToString("N"),
                Type: type,
                ProgressPct: Math.Clamp(_progressPct, 0, 100),
                OccurredAt: DateTimeOffset.UtcNow.ToString("O"));
            await Outbox.EnqueueAsync($"api/books/{BookId}/sessions", req);
            await LoadAsync();
        }
        catch (Exception ex) { _error = Errors.Friendly(ex, "Couldn't log that session."); }
        finally { _logging = false; }
    }

    private async Task DeleteAsync()
    {
        _deleting = true;
        try
        {
            var res = await Http.DeleteAsync($"api/books/{BookId}");
            res.EnsureSuccessStatusCode();
            Nav.NavigateTo("/library");
        }
        catch (Exception ex) { _error = Errors.Friendly(ex, "Couldn't remove the book."); _deleting = false; }
    }
}
