@page "/library"
@using Dewey.Shared.Contracts
@using Dewey.Web.Auth
@using Dewey.Web.Offline
@using Dewey.Web.Shared
@inject AuthSession Session
@inject ApiCache Cache

<PageTitle>Library - Dewey</PageTitle>

<div class="d-flex justify-content-between align-items-center mb-3">
    <h1 class="m-0">Library</h1>
    <a class="btn btn-primary" href="search">Add a book</a>
</div>

@if (!Session.IsSignedIn)
{
    <p>Please <a href="login">sign in</a>.</p>
    return;
}

@if (_books is null && _error is null)
{
    <Spinner Label="Loading library…" />
}
else if (_error is not null)
{
    <div class="alert alert-danger" role="alert">@_error</div>
}
else if (_books!.Length == 0)
{
    <div class="text-center py-5 text-muted">
        <p class="lead">Your library is empty.</p>
        <a class="btn btn-primary" href="search">Search for a book</a>
    </div>
}
else
{
    <div class="row row-cols-1 row-cols-md-3 g-3">
        @foreach (var b in _books)
        {
            <div class="col">
                <a class="card h-100 text-decoration-none text-reset" href="@($"book/{b.BookId}")"
                   aria-label="@($"{b.Title} by {string.Join(", ", b.Authors)}")">
                    <div class="card-body d-flex gap-3">
                        @if (!string.IsNullOrEmpty(b.CoverUrl))
                        {
                            <img src="@b.CoverUrl" alt="@($"Cover of {b.Title}")" style="width:80px; height:auto;" />
                        }
                        <div>
                            <div class="fw-bold">@b.Title</div>
                            <div class="text-muted small">@string.Join(", ", b.Authors)</div>
                            <div class="text-muted small">@b.LatestProgressPct% — @b.Status</div>
                        </div>
                    </div>
                </a>
            </div>
        }
    </div>
}

@code {
    private BookSummary[]? _books;
    private string? _error;

    protected override async Task OnInitializedAsync()
    {
        if (!Session.IsSignedIn) return;
        try { _books = await Cache.GetAsync<BookSummary[]>("api/books") ?? []; }
        catch (Exception ex) { _error = Errors.Friendly(ex, "Couldn't load your library."); }
    }
}
